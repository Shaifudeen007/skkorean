generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Admin {
  id        String    @id @default(uuid())
  email     String    @unique
  password  String
  name      String
  role      String    @default("ADMIN")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  activityLogs ActivityLog[]

  @@map("admins")
}

model User {
  id             String    @id @default(uuid())
  googleId       String?   @unique
  email          String    @unique
  name           String
  profilePicture String?
  password       String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  @@map("users")
}

model MainCategory {
  id     String @id @default(uuid())
  name   String @unique

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  categories Category[]

  @@map("main_categories")
}

model Category {
  id             String       @id @default(uuid())
  name           String
  slug           String       @unique
  image          String?
  status         Boolean      @default(true)
  mainCategoryId String
  mainCategory   MainCategory @relation(fields: [mainCategoryId], references: [id], onDelete: Restrict)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  products Product[]

  @@index([mainCategoryId])
  @@index([status])
  @@map("categories")
}

model Product {
  id          String @id @default(uuid())
  name        String
  description String

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  image String?

  mrp           Float?
  discountPrice Float?

  status Boolean @default(true)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([categoryId])
  @@index([status])
  @@map("products")
}

model Gallery {
  id          String  @id @default(uuid())
  url         String
  title       String?
  description String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@map("gallery")
}

model Enquiry {
  id      String  @id @default(uuid())
  name    String
  email   String
  phone   String?
  subject String?
  message String

  status String @default("PENDING")

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([status])
  @@map("enquiries")
}

model WebsiteSetting {
  id String @id @default(uuid())

  companyName String  @default("SK Korean Aesthetic Technologies")
  logo        String?
  favicon     String?

  contactEmail   String?
  contactPhone   String?
  contactAddress String?

  facebookUrl  String?
  instagramUrl String?
  twitterUrl   String?
  linkedinUrl  String?

  footerText String?

  seoDefaultTitle String?
  seoDefaultDesc  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("website_settings")
}

model ActivityLog {
  id String @id @default(uuid())

  adminId String
  admin   Admin  @relation(fields: [adminId], references: [id], onDelete: Cascade)

  action  String
  details String?

  createdAt DateTime @default(now())

  @@index([adminId])
  @@map("activity_logs")
}
